# Firebase web app config — PUBLIC by design (security lives in firestore.rules).
# Without these the app runs on the built-in seed/demo data source.
# Create the project at console.firebase.google.com (region: europe-west3 Frankfurt),
# add a Web App, then copy the values here as .env.local (gitignored).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_APP_ID=

# Vite base path: "/" with the custom domain, "/Vow/" on project pages.
# Set by the deploy workflow, not needed locally.
# VITE_BASE=/
